{
  "name": "valtex-server",
  "version": "1.0.0",
  "description": "VALTEX Backend API",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "lint": "echo 'No lint configured'",
    "test": "echo 'No tests configured'"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nanoid": "^3.3.7",
    "ua-parser-js": "^1.0.37"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "nodemonConfig": {
    "watch": ["."],
    "ext": "js,json",
    "ignore": ["node_modules/", "*.test.js"],
    "delay": 1000
  }
}
